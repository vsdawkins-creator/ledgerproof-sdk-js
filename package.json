{
  "name": "@ledgerproof/sdk",
  "version": "1.1.3",
  "description": "EU AI Act Article 50 cryptographic transparency receipts, anchored to Bitcoin. The TypeScript SDK with the Stripe-style attach() pattern.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/openai": {
      "types": "./dist/adapters/openai.d.ts",
      "import": "./dist/adapters/openai.js",
      "require": "./dist/adapters/openai.cjs"
    },
    "./verifier": {
      "types": "./dist/verifier.d.ts",
      "import": "./dist/verifier.js",
      "require": "./dist/verifier.cjs"
    },
    "./scitt": {
      "types": "./dist/scitt/index.d.ts",
      "import": "./dist/scitt/index.js",
      "require": "./dist/scitt/index.cjs"
    },
    "./witness": {
      "types": "./dist/witness/index.d.ts",
      "import": "./dist/witness/index.js",
      "require": "./dist/witness/index.cjs"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE", "package.json"],
  "scripts": {
    "build": "tsup src/index.ts src/adapters/openai.ts src/verifier.ts src/scitt/index.ts src/witness/index.ts --format esm,cjs --dts --clean --treeshake",
    "test": "vitest run",
    "test:live": "LEDGERPROOF_LIVE=1 vitest run test/live.test.ts",
    "lint": "tsc --noEmit",
    "format": "prettier --write src test"
  },
  "keywords": ["ai", "eu-ai-act", "article-50", "compliance", "provenance", "bitcoin", "gdpr"],
  "author": "Veronica S. Dawkins <veronica@ledgerproofhq.io>",
  "license": "Apache-2.0",
  "homepage": "https://ledgerproofhq.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vsdawkins-creator/ledgerproof-sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/vsdawkins-creator/ledgerproof-sdk-js/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "dependencies": {
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "prettier": "^3.2.0"
  }
}
